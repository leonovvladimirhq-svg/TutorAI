# ---- Telegram ----
TELEGRAM_BOT_TOKEN=000000:CHANGE_ME

# ---- Database ----
# Внутри docker-compose host = db; локально без docker — localhost
POSTGRES_USER=tutorai
POSTGRES_PASSWORD=change_me
POSTGRES_DB=tutorai
DATABASE_URL=postgresql+asyncpg://tutorai:change_me@db:5432/tutorai

# ---- Yandex Cloud / AI Studio ----
# Путь к JSON сервисного аккаунта (монтируется в контейнер, вне git)
YC_SA_KEY_FILE=/secrets/sa-key.json
YC_FOLDER_ID=CHANGE_ME
# OpenAI-совместимый endpoint Yandex AI Studio
LLM_ENDPOINT=https://llm.api.cloud.yandex.net/v1
# URI модели Qwen; подставится folder_id, если оставить плейсхолдер {folder}
# Заказчик указал Qwen3 30B-A3B. Точный идентификатор уточнить в AI Studio каталога.
LLM_MODEL_URI=gpt://{folder}/qwen3-30b-a3b/latest
LLM_TEMPERATURE=0.4
LLM_MAX_TOKENS=2000

# ---- SpeechKit (STT) ----
ENABLE_VOICE=true
SPEECHKIT_STT_URL=https://stt.api.cloud.yandex.net/speech/v1/stt:recognize
SPEECHKIT_LANG=ru-RU

# ---- Веб-панель академического руководителя ----
# Вход в панель управления ролями (http://<IP>:<WEB_PORT>)
WEB_ADMIN_USER=academ
WEB_ADMIN_PASSWORD=ABCD
# Секрет для подписи cookie-сессии (задайте длинную случайную строку)
WEB_SESSION_SECRET=change-me-please-web-secret
WEB_PORT=8080
# Опционально: Telegram ID, которому при старте назначается роль «Академический руководитель»
BOOTSTRAP_DIRECTOR_TG=

# ---- App ----
LOG_LEVEL=INFO
